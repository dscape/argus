FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libcairo2 \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

COPY pipeline/requirements.txt /tmp/pipeline-requirements.txt
COPY dev-tools/api/requirements.txt /tmp/api-requirements.txt
RUN pip install --no-cache-dir \
    -r /tmp/pipeline-requirements.txt \
    -r /tmp/api-requirements.txt

ENV PYTHONPATH=/app/src:/app

CMD ["sh", "-c", "cd /app/dev-tools && uvicorn api.main:app --host 0.0.0.0 --port 8000 --reload"]
