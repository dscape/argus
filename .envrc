# Auto-activate Python virtual environment via direnv
# Install direnv: brew install direnv
# Then add to your shell rc: eval "$(direnv hook zsh)"

# Load .env (API keys, HF_TOKEN, etc.)
dotenv_if_exists

if [ ! -d .venv ]; then
    echo "Creating virtual environment..."
    python3 -m venv .venv
fi

source .venv/bin/activate

# Install/update dev dependencies when pyproject.toml changes
if [ ! -f .venv/.dev-installed ] || [ pyproject.toml -nt .venv/.dev-installed ]; then
    echo "Installing dev dependencies..."
    pip install -e ".[dev]" -q
    touch .venv/.dev-installed
fi
